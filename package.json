{
  "name": "vercount-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --dir app dev",
    "build": "pnpm --dir app build",
    "start": "pnpm --dir app start",
    "lint": "pnpm --dir app lint",
    "db:generate": "pnpm --dir app db:generate",
    "db:migrate": "pnpm --dir app db:migrate",
    "react:build": "pnpm --dir package/react build",
    "react:lint": "pnpm --dir package/react lint"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.8",
      "@types/react-dom": "19.1.6"
    }
  }
}
